#!/bin/bash
# Sonance EQ pre-commit hook: regenerate the project and run the test suite when code changes.
# Skip with:  SKIP_SONANCE_TESTS=1 git commit …   or   git commit --no-verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [ "${SKIP_SONANCE_TESTS:-0}" = "1" ]; then
  echo "[pre-commit] skipped (SKIP_SONANCE_TESTS=1)"
  exit 0
fi

# Only run for Swift / project changes — keep doc-only commits fast.
if ! git diff --cached --name-only | grep -qE '\.swift$|project\.yml$'; then
  echo "[pre-commit] no Swift/project changes — skipping tests"
  exit 0
fi

if ! command -v xcodegen >/dev/null 2>&1; then
  echo "[pre-commit] xcodegen not found — skipping (install: brew install xcodegen)"
  exit 0
fi

echo "[pre-commit] xcodegen generate + xcodebuild test …"
xcodegen generate >/dev/null
if xcodebuild test \
      -project SonanceEQ.xcodeproj -scheme SonanceEQ \
      -destination 'platform=macOS,arch=arm64' -quiet; then
  echo "[pre-commit] ✓ tests passed"
else
  echo "[pre-commit] ✗ tests failed — commit aborted (use --no-verify to override)"
  exit 1
fi
